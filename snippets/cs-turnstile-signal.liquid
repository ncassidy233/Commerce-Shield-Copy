{% comment %}
  Commerce Shield — Turnstile form gate for login/register.

  HOW TO USE:
    {% render 'cs-turnstile-signal' %}

  WHERE TO ADD:
    - customers/login.liquid → inside the form, right before the submit button
    - customers/register.liquid → inside the form, right before the submit button

  WHAT IT DOES:
    Intercepts form submit and runs a Turnstile challenge before allowing it.
    - Clean humans:       invisible, passes in ~100ms, form submits normally.
    - Suspicious users:   Cloudflare shows a quick checkbox challenge automatically.
    - Confirmed bots:     server-side verify fails, form submit is blocked with an error message.
    - Analytics pixels (GA4, Meta, etc.) are also suppressed for confirmed bots.
    - Network errors always fail open — real users are never stuck.
{% endcomment %}

<div id="cs-ts-widget" style="margin-top:12px"></div>
<div id="cs-ts-error" style="display:none;margin-top:10px;padding:10px 14px;background:#fff2f2;border:1px solid #fca5a5;border-radius:6px;color:#991b1b;font-size:14px">
  We were unable to verify your request. Please refresh the page and try again.
</div>

<script>
(function() {
  'use strict';

  var SITE_KEY = '0x4AAAAAADI8ti4vY8C6Vy8O';
  var WORKER   = 'https://commerce-shield-prod.ncassidy.workers.dev';
  var VERIFY_API = 'https://commerce-shield.onrender.com/api/turnstile-verify';
  var SHOP = {{ shop.permanent_domain | json }};

  var widgetId = null;
  var pendingSubmit = null;
  var verified = false;
  var verifyInFlight = false;
  var VERIFY_TTL_MS = 15 * 60 * 1000;
  var VERIFIED_KEY = 'cs_ts_verified_until_account';

  function getVerifiedUntil() {
    try {
      return parseInt(sessionStorage.getItem(VERIFIED_KEY) || '0', 10) || 0;
    } catch (_) {
      return 0;
    }
  }

  function markVerified() {
    verified = true;
    try {
      sessionStorage.setItem(VERIFIED_KEY, String(Date.now() + VERIFY_TTL_MS));
    } catch (_) {}
  }

  function hasRecentVerification() {
    return getVerifiedUntil() > Date.now();
  }

  function showError(msg) {
    var el = document.getElementById('cs-ts-error');
    if (el) {
      el.textContent = msg || 'We were unable to verify your request. Please refresh and try again.';
      el.style.display = 'block';
    }
  }

  function hideError() {
    var el = document.getElementById('cs-ts-error');
    if (el) el.style.display = 'none';
  }

  function verifyTurnstileToken(token) {
    var payload = JSON.stringify({ token: token, action: 'account', shop: SHOP });
    return fetch(VERIFY_API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: payload,
      keepalive: true
    })
    .then(function(r) { return r.json(); })
    .catch(function() {
      return fetch(WORKER + '/api/turnstile-verify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: payload,
        keepalive: true
      }).then(function(r) { return r.json(); });
    });
  }

  function onToken(token) {
    if (verifyInFlight) return;
    verifyInFlight = true;
    // Got a token from Turnstile — verify server-side before allowing submit.
    verifyTurnstileToken(token)
    .then(function(d) {
      verifyInFlight = false;
      if (d.ok) {
        // Verified human — suppress pixels just in case, then allow form submit.
        markVerified();
        hideError();
        if (pendingSubmit) {
          var f = pendingSubmit;
          pendingSubmit = null;
          f.submit();
        }
      } else {
        // Confirmed bot — block submit, suppress analytics pixels, show error.
        verified = false;
        pendingSubmit = null;
        showError('Security check failed. If you are a real person, please refresh the page and try again.');
        var pg = window.__CommerceShieldPixelGuard;
        if (pg && typeof pg.markBot === 'function') pg.markBot('turnstile_verify_fail');
        // Reset widget so a genuine retry is possible.
        if (widgetId !== null && window.turnstile) window.turnstile.reset(widgetId);
      }
    })
    .catch(function() {
      verifyInFlight = false;
      // Network error — fail open so real users are never stuck.
      markVerified();
      if (pendingSubmit) {
        var f = pendingSubmit;
        pendingSubmit = null;
        f.submit();
      }
    });
  }

  function onError() {
    // Turnstile challenge error (e.g. network) — fail open.
    markVerified();
    if (pendingSubmit) {
      var f = pendingSubmit;
      pendingSubmit = null;
      f.submit();
    }
  }

  function render() {
    if (typeof window.turnstile === 'undefined') return;
    widgetId = window.turnstile.render('#cs-ts-widget', {
      sitekey: SITE_KEY,
      // 'managed' → Cloudflare decides: invisible for clean browsers,
      // shows a checkbox challenge for suspicious ones automatically.
      appearance: 'interaction-only',
      execution: 'execute',
      callback: onToken,
      'error-callback': onError,
      'unsupported-callback': onError
    });
  }

  function interceptForms() {
    // Find all account forms on the page (login + register share this pattern).
    var forms = document.querySelectorAll('form[action*="/account"]');
    forms.forEach(function(form) {
      form.addEventListener('submit', function(e) {
        if (verified || hasRecentVerification()) {
          verified = true;
          return;
        }
        if (verifyInFlight) {
          e.preventDefault();
          return;
        }
        e.preventDefault();
        hideError();
        pendingSubmit = form;
        if (widgetId !== null && window.turnstile) {
          window.turnstile.reset(widgetId);
          window.turnstile.execute(widgetId);
        } else {
          // Turnstile didn't load — fail open so real users are never stuck.
          markVerified();
          form.submit();
        }
      });
    });
  }

  window.__csTsOnload = function() {
    render();
    interceptForms();
  };

  var s = document.createElement('script');
  s.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit&onload=__csTsOnload';
  s.async = true;
  document.head.appendChild(s);
})();
</script>