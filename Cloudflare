.int-slider::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;border-radius:50%;background:#2563eb;cursor:pointer;box-shadow:0 1px 4px rgba(37,99,235,.35)}
.int-num{width:50px;padding:5px 7px;border:1px solid #e2e8f0;border-radius:7px;font-size:13px;font-weight:700;text-align:center}
