</head>
<body>
<div class="cs-hdr">
  <div class="cs-brand">
    <svg width="24" height="24" viewBox="0 0 28 28" fill="none"><path d="M14 2L4 6v8c0 5.5 4.3 10.7 10 12 5.7-1.3 10-6.5 10-12V6L14 2z" fill="#3b82f6" opacity=".9"/><path d="M10 14l3 3 5-5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <div><div class="cs-brand-name">Commerce Shield</div><div class="cs-brand-sub">Bot Protection Control Plane</div></div>
  </div>
  <div class="cs-hdr-ctrls">
    <input id="shopInput" class="inp" placeholder="your-store.myshopify.com" value="${shop}" style="width:220px">
    <select id="daysSelect" class="sel">
      <option value="7">7 days</option><option value="14">14 days</option><option value="30" selected>30 days</option><option value="90">90 days</option>
    </select>
    <button class="btn btn-p" onclick="doRefresh()">&#8635; Refresh</button>
    <button id="pgBtn" class="btn btn-d" onclick="openPixelGuardGuide()">Pixel Guard Guide</button>
    <a class="doc-link" href="/documentation" target="_blank" rel="noopener noreferrer">Read Documentation</a>
  </div>
</div>
<div class="body">
  <div id="cs-alert" class="alert"></div>
  <div id="cs-overview"><div class="empty"><p style="font-size:32px;margin-bottom:8px">&#128737;</p><p>Enter your shop and click <strong>Refresh</strong> to load analytics.</p></div></div>
  <div id="cs-settings" style="display:none">
    <div class="card">
      <div class="card-hd">&#9881;&#65039; Bot Guard Controls</div>
      <div class="int-wrap">
        <div class="int-hd"><span class="int-hd-lbl">Protection Intensity</span><span class="int-badge" id="intBadge">5</span></div>
        <div class="int-sub">Intensity 3 = threshold 0.87 (above the 0.85 soft-signal cap &mdash; only hard bot signals classify). Intensity 5 = 0.84 threshold (soft signals can exceed it).</div>
        <div class="int-row">
          <input type="range" id="intSlider" class="int-slider" min="1" max="10" value="5" oninput="onSlider(this.value)">
          <input type="number" id="intNum" class="int-num" min="1" max="10" value="5" oninput="onNum(this.value)">
        </div>
      </div>
      <div class="tog-row">
        <div class="tog-text"><strong>Bot Protection Enabled</strong><span>Master switch. Off = monitor-only; bots tracked but NOT suppressed.</span></div>
        <label class="tog"><input type="checkbox" id="botToggle"><span class="tog-sl"></span></label>
      </div>
      <div class="save-row">
        <button class="btn btn-p" onclick="saveSettings()">Save Changes</button>
        <button class="btn btn-d" onclick="rollbackProfile()">Rollback to 4/10</button>
        <span class="save-ok" id="saveOk">&#10003; Saved</span>
      </div>
    </div>
  </div>
</div>
<script>
const API='${origin}';
const LSKEY_PG='cs_pg_sync:';
const LSKEY_TOK='cs_admin_token';
let _lastFetch=null;
let _pendingInt=null;

(function(){
  const p=new URLSearchParams(window.location.search);
  const q=(p.get('shop')||'gerberchildrenswear.myshopify.com').trim().toLowerCase();
  if(q&&/^[a-z0-9][a-z0-9-]*\\.myshopify\\.com$/.test(q)){const el=document.getElementById('shopInput');if(el)el.value=q;}
})();

function getTok(){try{return(sessionStorage.getItem(LSKEY_TOK)||'').trim()}catch{return''}}
function setTok(t){try{if(t)sessionStorage.setItem(LSKEY_TOK,t)}catch{}}
function clearTok(){try{sessionStorage.removeItem(LSKEY_TOK)}catch{}}
function promptTok(){
  try{
    const t=(window.prompt('Commerce Shield admin token:')||'').trim();
    if(t)setTok(t);
    return t;
  }catch{return ''}
}

async function adminFetch(path,opt,mode){
  const cfg=Object.assign({promptOnAuth:true,throwOnAuth:true},mode||{});
  const init=Object.assign({credentials:'include',cache:'no-store'},opt||{});
  init.headers=Object.assign({},init.headers||{});
  let tok=getTok();
  if(!tok&&cfg.promptOnAuth){
    tok=promptTok();
    if(!tok){
      if(!cfg.throwOnAuth)return null;
      throw new Error('Admin session required. Open this app from Shopify Admin or provide admin token.');
    }
  }
  if(tok)init.headers.Authorization='Bearer '+tok;

  let res=await fetch(path,init);
  let data=await res.json().catch(()=>({}));

  if((res.status===401||res.status===403)&&cfg.promptOnAuth){
    tok=promptTok();
    if(tok){
      init.headers=Object.assign({},init.headers,{Authorization:'Bearer '+tok});
      res=await fetch(path,init);
      data=await res.json().catch(()=>({}));
    }
  }

  if(res.status===401||res.status===403){
    clearTok();
    if(cfg.throwOnAuth){
      throw new Error('Admin session required. Open this app from Shopify Admin or provide admin token.');
    }
    if(!cfg.throwOnAuth)return null;
  }

  if(!res.ok){
    throw new Error(data.error||'API error '+res.status);
  }
  return data;
}

// apiFetch: admin/* always bypasses cache; dashboard uses edge cache
async function apiFetch(path,opt){
  const isAdmin=path.includes('/api/admin/');
  if(isAdmin){
    return adminFetch(path,opt,{promptOnAuth:true,throwOnAuth:true});
  }
  const init=Object.assign({credentials:'include',cache:isAdmin?'no-store':'default'},opt||{});
  init.headers=Object.assign({},init.headers||{});
  const res=await fetch(path,init);
  const data=await res.json().catch(()=>({}));
  if(!res.ok)throw new Error(data.error||'API error '+res.status);
  return data;
}

function esc(v){const d=document.createElement('div');d.textContent=v==null?'':String(v);return d.innerHTML}
function fmt(n){return(Number(n)||0).toLocaleString()}
function pct(v,d){return(Number(v)||0).toFixed(d??1)+'%'}
function shop(){return(document.getElementById('shopInput').value||'').trim()}
function days(){return document.getElementById('daysSelect').value||'30'}
function clamp(n){if(!Number.isFinite(n))return 5;return Math.max(1,Math.min(10,Math.round(n)))}
function dstr(v){if(!v)return '\u2014';const s=String(v).replace(' ','T');const d=new Date(s.endsWith('Z')?s:s+'Z');return isNaN(d)?String(v):d.toLocaleString()}
function showAlert(txt,tone){
  const el=document.getElementById('cs-alert');
  if(!txt){el.className='alert';el.textContent='';return}
  el.className='alert show a-'+(tone||'ok');el.textContent=txt;
  if(tone==='ok')setTimeout(function(){if(el.textContent===txt){el.className='alert';el.textContent=''}},5000);
}
function chip(t,c){return '<span class="chip ch-'+c+'">'+esc(t)+'</span>'}
function metric(cls,lbl,val,hint){return '<div class="metric '+cls+'"><div class="m-lbl">'+esc(lbl)+'</div><div class="m-val">'+esc(val)+'</div><div class="m-hint">'+esc(hint)+'</div></div>'}
function healthRow(dc,lbl,val,detail){return '<div class="hr"><div class="hr-icon"><span class="dot d-'+dc+'"></span></div><div class="hr-body"><div class="hr-label">'+esc(lbl)+'</div><div class="hr-detail">'+esc(val)+(detail?' \xB7 '+esc(detail):'')+'</div></div></div>'}

// Intensity controls - slider + number input stay in sync
function syncInt(n){document.getElementById('intSlider').value=n;document.getElementById('intNum').value=n;document.getElementById('intBadge').textContent=n;_pendingInt=n;}
function onSlider(v){const n=clamp(Number(v));document.getElementById('intNum').value=n;document.getElementById('intBadge').textContent=n;_pendingInt=n;}
function onNum(v){const n=clamp(Number(v));document.getElementById('intSlider').value=n;document.getElementById('intBadge').textContent=n;_pendingInt=n;}
function applyIntent(intent){
  const n=clamp(Number(intent&&intent.botProtectionIntensity)||5);
  syncInt(n);
  document.getElementById('botToggle').checked=!intent||intent.botProtectionEnabled!==false;
}

// saveSettings: POST then apply response directly \u2014 no stale cache reload
async function saveSettings(){
  const s=shop();if(!s){showAlert('Enter a valid .myshopify.com domain first.','err');return}
  const intensity=_pendingInt!=null?_pendingInt:clamp(Number(document.getElementById('intSlider').value));
  const enabled=document.getElementById('botToggle').checked;
  try{
    const result=await apiFetch(API+'/api/admin/settings',{
      method:'POST',cache:'no-store',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({shop:s,intent:{botProtectionEnabled:enabled,botProtectionIntensity:intensity}})
    });
    const saved=result&&result.settings&&result.settings.intent;
    if(saved)applyIntent(saved);
    const ok=document.getElementById('saveOk');ok.className='save-ok show';
    setTimeout(function(){ok.className='save-ok'},3000);
    showAlert('Saved \u2014 intensity '+intensity+'/10, protection '+(enabled?'ON':'OFF')+'.','ok');
  }catch(e){showAlert(e.message||'Save failed.','err')}
}

async function rollbackProfile(){
  if(!window.confirm('Set intensity to 4/10 with protection ON?'))return;
  const s=shop();if(!s)return;
  try{
    const result=await apiFetch(API+'/api/admin/settings',{
      method:'POST',cache:'no-store',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({shop:s,intent:{botProtectionEnabled:true,botProtectionIntensity:4}})
    });
    applyIntent(result&&result.settings&&result.settings.intent||{botProtectionEnabled:true,botProtectionIntensity:4});
    showAlert('Rolled back to 4/10 with protection ON.','ok');
  }catch(e){showAlert(e.message||'Rollback failed.','err')}
}

function renderDash(dash,intent){
  const t=dash.totals||{};
  const h=dash.health||{};
  const g=dash.gtm||{};
  const turn=dash.turnstile||{};
  const total=Number(t.totalVisits)||0;
  const bots=Number(t.botVisits)||0;
  const humans=Number(t.humanVisits)||0;
  const crawlers=Number(t.allowedCrawlers)||0;
  const componentTotal=Number(t.componentTotalVisits)||(humans+bots+crawlers);
  const sessionDelta=Number(t.sessionDelta)||0;
  const botRate=total>0?(bots/total*100):0;
  const monitorOnly=h.monitorOnlyMode===true;
  const botEnabled=(!intent||intent.botProtectionEnabled!==false)&&!monitorOnly;
  const intensity=clamp(Number(intent&&intent.botProtectionIntensity)||5);
  const gtm24h=Number(h.gtmEvents24h)||0;
  const pixels24h=Number(h.pixelsProtected24h)||0;
  const turn24h=Number(h.turnstile24h)||0;
  const flags=Array.isArray(h.flags)?h.flags:[];

  var html='';
  if(monitorOnly){html+='<div class="alert show a-warn" style="margin-bottom:14px">Monitor-only mode is active \u2014 bots are tracked but NOT suppressed. Pixels protected will always be 0. This is correct behaviour.</div>';}
  else if(!botEnabled){html+='<div class="alert show a-warn" style="margin-bottom:14px">Bot protection is disabled. Use Bot Guard Controls below to enable suppression.</div>';}
  html+='<div id="pgGuideHint"></div>';

  html+='<div class="sec-hd"><span class="sec-title">Traffic Overview \xB7 '+esc(days())+' days</span>';
  html+='<span class="ts">'+(_lastFetch?'Updated '+_lastFetch.toLocaleTimeString():'')+'</span></div>';

  var br=botRate>50?'c-r':botRate>25?'c-a':'c-g';
  html+='<div class="metrics">';
  html+=metric('c-s','Total Sessions',fmt(total),'Humans + bots + crawlers');
  html+=metric('c-g','Humans',fmt(humans),'Classified as real users');
  html+=metric('c-r','Bots Detected',fmt(bots),'High-confidence bot classifications');
  html+=metric(br,'Bot Rate',pct(botRate),'Bots \xF7 total sessions');
  html+=metric('c-b','Allowed Crawlers',fmt(crawlers),'Googlebot, Bingbot etc');
  html+=metric('c-b','Pixels Protected',fmt(t.pixelsProtected||0),monitorOnly?'Always 0 in monitor mode':'Suppressed pixel fires');
  html+=metric('c-s','Emails Blocked',fmt(t.disposableEmailsBlocked||0),'Disposable email rejections');
  html+='</div>';

  html+='<div class="g2">';
  // Health card
  html+='<div class="card"><div class="card-hd">System Health</div>';
  html+=healthRow(Math.abs(sessionDelta)<=Math.max(3,total*0.03)?'g':'a','Session Math',fmt(humans)+' humans + '+fmt(bots)+' bots + '+fmt(crawlers)+' crawlers = '+fmt(componentTotal),sessionDelta?'Adjusted by '+fmt(Math.abs(sessionDelta))+' from stored raw total':'Aligned');
  html+=healthRow(gtm24h>0?'g':'a','GTM Server Events (24h)',gtm24h>0?fmt(gtm24h)+' events':'0 events \u2014 check GTM server-side tag','Last: '+dstr(h.gtmLastSeen24h||g.lastSeen));
  html+=healthRow(monitorOnly?(pixels24h===0?'g':'r'):'s','Pixel Suppression',monitorOnly?(pixels24h===0?'Aligned (0 \u2014 correct)':'\u26A0 Unexpected: '+fmt(pixels24h)):fmt(t.pixelsProtected||0)+' in period','');
  html+=healthRow(turn24h>0?'g':'s','Turnstile (24h)',turn24h>0?fmt(turn24h)+' verifications':'None','Pass: '+fmt(turn.passed||0)+' / Fail: '+fmt(turn.failed||0)+' / Last: '+dstr(h.turnstileLastSeen24h||turn.lastSeen));
  html+=healthRow(monitorOnly?'a':botEnabled?'g':'s','Protection Mode',monitorOnly?'Monitor-only (fail-open)':botEnabled?'Live suppression at '+intensity+'/10':'Suppression disabled','');
  if(flags.length){flags.forEach(function(f){html+=healthRow(f.level==='bad'?'r':f.level==='warn'?'a':'s',(f.code||'notice').replace(/_/g,' '),(f.message||''),'');});}
  else{html+=healthRow('g','All Signals Clear','No alignment issues detected','');}
  html+='</div>';

  // Sources table
  html+='<div class="card"><div class="card-hd">Traffic Sources</div>';
  html+='<table class="tbl"><thead><tr><th>Source</th><th>Visits</th><th>Bots</th><th>Bot %</th></tr></thead><tbody>';
  var sources=dash.sources||[];
  if(sources.length){sources.forEach(function(r){var rp=Number(r.count)?((Number(r.bots)||0)/Number(r.count)*100):0;var rc=rp>50?'ch-r':rp>20?'ch-a':'ch-s';html+='<tr><td class="mono">'+esc(r.source||'direct')+'</td><td>'+fmt(r.count)+'</td><td>'+fmt(r.bots)+'</td><td>'+chip(pct(rp,0),rc.slice(3))+'</td></tr>';});}
  else{html+='<tr><td colspan="4" style="text-align:center;color:#94a3b8;padding:18px">No source data yet</td></tr>';}
  html+='</tbody></table></div>';
  html+='</div>'; // g2

  // Recent visits on-demand
  html+='<div class="card"><div class="card-hd">Recent Human, Bot &amp; Crawler Activity <span style="font-size:11px;font-weight:400;color:#94a3b8">(last 50, loaded on demand to save quota)</span></div>';
  html+='<div id="recent-wrap"><button class="btn btn-d" onclick="loadRecent()">Load Recent Visits</button></div></div>';

  document.getElementById('cs-overview').innerHTML=html;
}

async function loadRecent(){
  var s=shop();if(!s)return;
  var el=document.getElementById('recent-wrap');if(!el)return;
  el.innerHTML='<div class="loading">Loading\u2026</div>';
  try{
    var data=await apiFetch(API+'/api/recent?shop='+encodeURIComponent(s)+'&limit=50');
    var visits=data.visits||[];
    var t='<table class="tbl"><thead><tr><th>Time</th><th>Type</th><th>Score</th><th>Conf</th><th>Source</th><th>Page</th></tr></thead><tbody>';
    if(visits.length){visits.forEach(function(v){var typ=v.is_legitimate?'Crawler':v.is_bot?'Bot':'Human';var tc=v.is_legitimate?'ch-b':v.is_bot?'ch-r':'ch-g';var cc=v.confidence==='high'?'ch-r':v.confidence==='medium'?'ch-a':'ch-s';t+='<tr><td class="mono" style="white-space:nowrap">'+esc(v.created_at?new Date(v.created_at+'Z').toLocaleTimeString():'\u2014')+'</td><td>'+chip(typ,tc.slice(3))+'</td><td>'+((Number(v.bot_score)||0).toFixed(2))+'</td><td>'+chip(v.confidence||'low',cc.slice(3))+'</td><td class="mono">'+esc(v.source||'direct')+'</td><td class="mono">'+esc((v.page||'').slice(0,48)||'/')+'</td></tr>';});}
    else{t+='<tr><td colspan="6" style="text-align:center;color:#94a3b8;padding:18px">No visits recorded</td></tr>';}
    t+='</tbody></table>';el.innerHTML=t;
  }catch(e){el.innerHTML='<p style="color:#dc2626;font-size:13px;padding:8px">'+esc(e.message)+'</p>';}
}

async function doRefresh(){
  var s=shop();
  if(!s){showAlert('Enter a valid .myshopify.com domain first.','err');return}
  document.getElementById('cs-overview').innerHTML='<div class="loading">Loading dashboard\u2026</div>';
  showAlert('','ok');
  try{
    // Dashboard should render even when admin auth is unavailable.
    var results=await Promise.all([
      apiFetch(API+'/api/dashboard?shop='+encodeURIComponent(s)+'&days='+encodeURIComponent(days())),
      adminFetch(API+'/api/admin/settings?shop='+encodeURIComponent(s),{}, {promptOnAuth:false,throwOnAuth:false})
    ]);
    var dash=results[0];var settingsResp=results[1];
    _lastFetch=new Date();
    var intent=settingsResp&&settingsResp.settings&&settingsResp.settings.intent||{};
    renderDash(dash,intent);
    applyIntent(intent);
    document.getElementById('cs-settings').style.display='block';
    updatePgBtn(s);
  }catch(e){
    document.getElementById('cs-overview').innerHTML='<div class="empty"><p style="font-size:28px;margin-bottom:8px">\u26A0\uFE0F</p><p>'+esc(e.message||'Failed to load dashboard.')+'</p></div>';
    showAlert(e.message||'Load failed.','err');
  }
}

async function updatePgBtn(s){
  var btn=document.getElementById('pgBtn');if(!btn||!s)return;
  btn.textContent='Checking guide\u2026';btn.disabled=true;
  btn.className='btn btn-d';
  if(!getTok()){renderPgGuideHint(null,s);btn.textContent='Pixel Guard Guide';btn.disabled=false;return}
  try{
    var d=await adminFetch(API+'/api/admin/pixel-guard-status?shop='+encodeURIComponent(s),{}, {promptOnAuth:false,throwOnAuth:false});
    if(!d){renderPgGuideHint(null,s);btn.textContent='Pixel Guard Guide';btn.className='btn btn-d';btn.disabled=false;return}
    renderPgGuideHint(d,s);
    btn.textContent=d.isActive?'\u2713 Pixel Guard Active':'\u26A0 Guard Inactive \u2014 Open Guide';
    btn.className='btn '+(d.isActive?'btn-g':'btn-r');
  }catch{renderPgGuideHint(null,s);btn.textContent='Pixel Guard Guide';btn.className='btn btn-d';}
  btn.disabled=false;
}

function openPixelGuardGuide(){
  var s=shop();
  var q=s?('?shop='+encodeURIComponent(s)):'';
  window.open(API+'/pixel-guard-guide'+q,'_blank','noopener,noreferrer');
}

function renderPgGuideHint(status,s){
  var host=document.getElementById('pgGuideHint');
  if(!host)return;
  var q=s?('?shop='+encodeURIComponent(s)):'';
  var link=API+'/pixel-guard-guide'+q;
  if(status&&status.isActive){
    host.innerHTML='';
    return;
  }
  var tone='a-warn';
  var msg='Pixel Guard is inactive or unverified on the current theme. Open the setup guide and copy the snippet into <head>.';
  if(status&&status.themeRole){
    msg='Pixel Guard is inactive on '+status.themeRole+' theme. Open the guide, copy the snippet, and place it at the top of <head>.';
  }
  host.innerHTML='<div class="alert show '+tone+'" style="margin-bottom:14px">'+esc(msg)+' <a href="'+link+'" target="_blank" rel="noopener noreferrer" style="font-weight:700;color:inherit;text-decoration:underline">Open Pixel Guard Guide</a></div>';
}

if(document.getElementById('shopInput').value){setTimeout(doRefresh,150);}
<\/script>
</body>
</html>`;
}
