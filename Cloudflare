.ch-g{background:#dcfce7;color:#166534}.ch-r{background:#fee2e2;color:#991b1b}.ch-a{background:#fef3c7;color:#92400e}.ch-b{background:#dbeafe;color:#1d4ed8}.ch-s{background:#f1f5f9;color:#475569}
.hr{display:flex;align-items:flex-start;gap:9px;padding:9px 0;border-bottom:1px solid #f1f5f9}
.hr:last-child{border-bottom:none}.hr-icon{padding-top:2px;flex-shrink:0}.hr-body{flex:1;min-width:0}
.hr-label{font-size:13px;font-weight:600;color:#0f172a}.hr-detail{font-size:11px;color:#64748b;margin-top:2px}
.tog-row{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid #f1f5f9}
.tog-row:last-of-type{border-bottom:none}
.tog-text strong{display:block;font-size:13px;font-weight:600;color:#0f172a}
